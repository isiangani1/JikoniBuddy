{
  "name": "jikoni-baddies",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev:all": "concurrently --kill-others-on-fail -p \"[{name}]\" -n \"gateway,web,buddy,buyer,seller,order,menu,health\" -c \"red,cyan,magenta,blue,yellow,green,white,gray\" \"cd apps/api-gateway && npx nest start --watch\" \"cd apps/web && npx next dev\" \"cd apps/buddy-service && npx nest start --watch\" \"cd apps/buyer-service && npx nest start --watch\" \"cd apps/seller-service && npx nest start --watch\" \"cd apps/order-service && npx nest start --watch\" \"cd apps/menu-service && npx nest start --watch\" \"npx wait-on http://127.0.0.1:4000/health http://127.0.0.1:4010/health http://127.0.0.1:4005/health http://127.0.0.1:4007/health http://127.0.0.1:4004/health http://127.0.0.1:4006/health && npm run health:all || npm run health:all\"",
    "dev:gateway": "cd apps/api-gateway && npx nest start --watch",
    "build:gateway": "npx tsc -p apps/api-gateway/tsconfig.json",
    "ci:gateway": "npx tsc -p apps/api-gateway/tsconfig.json --noEmit",
    "health:all": "node scripts/healthcheck.mjs"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/bcryptjs": "2.4.6",
    "@types/express": "^5.0.0",
    "@types/http-proxy": "^1.17.16",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/leaflet": "1.9.12",
    "@types/node": "20.14.10",
    "@types/react": "19.2.14",
    "@types/supertest": "^6.0.2",
    "autoprefixer": "^10.4.27",
    "concurrently": "9.0.1",
    "dotenv": "16.4.5",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "postcss": "^8.5.8",
    "prettier": "^3.4.2",
    "prisma": "^5.22.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "tailwindcss": "^4.2.2",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.5.4",
    "typescript-eslint": "^8.20.0",
    "wait-on": "7.2.0"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/microservices": "^11.1.17",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.17",
    "@nestjs/websockets": "^11.1.17",
    "@prisma/client": "^5.22.0",
    "@tanstack/react-query": "^5.91.3",
    "@tanstack/react-query-devtools": "^5.91.3",
    "bcryptjs": "2.4.3",
    "dotenv": "16.4.5",
    "express": "^4.21.2",
