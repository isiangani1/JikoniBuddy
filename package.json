  "scripts": {
    "dev:all": "concurrently -k -p \"[{name}]\" -n \"gateway,web,buddy,buyer,seller,order,menu\" -c \"red,cyan,magenta,blue,yellow,green,white\" \"cd apps/api-gateway && npx nest start --watch\" \"cd apps/web && npx next dev\" \"cd apps/buddy-service && npx nest start --watch\" \"cd apps/buyer-service && npx nest start --watch\" \"cd apps/seller-service && npx nest start --watch\" \"cd apps/order-service && npx nest start --watch\" \"cd apps/menu-service && npx nest start --watch\"",
    "dev:gateway": "cd apps/api-gateway && npx nest start --watch"
  },
