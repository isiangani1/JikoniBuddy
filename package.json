    "http-proxy": "^1.18.1",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "leaflet": "1.9.4",
    "next": "14.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-leaflet": "4.2.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.12"
